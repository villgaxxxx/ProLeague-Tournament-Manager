{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://proleague-api.somee.com/api/:path*"
    },
    {
      "source": "/matchHub/:path*",
      "destination": "http://proleague-api.somee.com/matchHub/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}